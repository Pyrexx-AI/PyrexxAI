<file path="app/globals.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

/* Custom Base Styles */
html {
  scroll-behavior: smooth;
  scroll-padding-top: 80px; /* Accounts for fixed navbar height */
}

body {
  /* Prevent horizontal scroll issues with absolute positioning */
  overflow-x: hidden;
  /* OpenType features for sharper numerals */
  font-feature-settings: "cv11", "ss01";
  font-variant-numeric: tabular-nums;
}

/* Stat number styling */
.stat-number {
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.03em;
}

/* Waveform animation for hero mockup */
@keyframes wave {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1); }
}

.wave-bar {
  display: inline-block;
  width: 3px;
  border-radius: 2px;
  background: currentColor;
  animation: wave 1s ease-in-out infinite;
  transform-origin: bottom;
}

.wave-bar:nth-child(1) { animation-delay: 0s; height: 12px; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; height: 20px; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; height: 28px; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; height: 16px; }
.wave-bar:nth-child(5) { animation-delay: 0.4s; height: 24px; }
.wave-bar:nth-child(6) { animation-delay: 0.5s; height: 12px; }
.wave-bar:nth-child(7) { animation-delay: 0.25s; height: 18px; }

/* Reduce motion override */
@media (prefers-reduced-motion: reduce) {
  .wave-bar { 
    animation: none; 
    transform: scaleY(0.6); 
  }
  .animate-pulse-glow {
    animation: none;
    box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.39);
  }
}
